# ─────────────────────────────────────────────────────────────────────────────
# SubhaLagna Matrimony — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Server Configuration
PORT=5000
NODE_ENV=development

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# Database (MongoDB)
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/subhalagna
MONGO_URI=your_mongodb_connection_uri

# ── CORS — Frontend URL (REQUIRED) ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Production Domain (Optional - used for tidy Server Logs) ─────────────────
# When deployed, set this to your actual backend domain (e.g., https://api.yourdomain.com)
BACKEND_URL=

# ── JWT (REQUIRED) ────────────────────────────────────────────────────────────
# These secrets secure your logins and sessions.
JWT_SECRET=subhalagna_v2_access_secret_long_random_string_1234567890abcdef
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=subhalagna_v2_refresh_secret_long_random_string_1234567890abcdef
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay Payment Gateway (Test or Live)
# Get these from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret


# Email Service (Powered by Nodemailer)
# For Gmail: 
# 1. Enable 2-Factor Authentication on your Google Account.
# 2. Generate an "App Password" (Security > App Passwords).
# 3. Use that 16-character code as SMTP_PASS below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password_here

# App Branding
APP_NAME=SubhaLagna
BRAND_PRIMARY=Subha
BRAND_SECONDARY=Lagna
WHATSAPP_COUNTRY_CODE=91
PRODUCTION_DOMAIN=bahaghara.in
EMAIL_FROM="SubhaLagna <noreply@subhalagna.com>"

# Bank Details for Manual Payments
BANK_ACC_NAME="SubhaLagna Matrimony"
BANK_ACC_NO="1234567890"
BANK_IFSC="SBIN0001234"
BANK_UPI_ID="subhalagna@upi"

# ── Storage Configuration ──────────────────────────────────────────────────────
# Options: local | s3
STORAGE_TYPE=local

# AWS S3 Credentials (only if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_s3_bucket_name

